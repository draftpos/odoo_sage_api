<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_havano_sage_queue_process" model="ir.cron">
            <field name="name">Sage Sync Queue Processor</field>
            <field name="model_id" ref="model_havano_sage_queue"/>
            <field name="state">code</field>
            <field name="code">model.process_queue()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_havano_sage_poller" model="ir.cron">
            <field name="name">Sage Sync Incoming Poller</field>
            <field name="model_id" ref="model_havano_sage_poller"/>
            <field name="state">code</field>
            <field name="code">model.cron_poll_sage_changes()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
